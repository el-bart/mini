#!/bin/bash
set -euo pipefail
app=$(basename "$0")
img='hermes-agent'
net='ollama-net'

cfg_dir="$HOME/.config/hermes-agent"
home_dir="$cfg_dir/home"
allowed_paths="$cfg_dir/allowed_paths"

mkdir -p "$cfg_dir"
mkdir -p "$home_dir"
[ -f "$allowed_paths" ] || cat <<EOF > "$allowed_paths"
^/tmp/tmp\\.
EOF

function ensure_allowed # <1:dir>
{
  grep -q -f "$allowed_paths" <<< "$(readlink -e "$1")" && return 0
  return 1
}

flags=()

stty -a > /dev/null 2>&1 && flags+=(--interactive)
flags+=(--tty)
flags+=(--rm)
flags+=(--init)
flags+=(--user="$(id -u):$(id -g)")
flags+=(--name="$img-$USER-$$")

flags+=(--env              HOME=/home/hermes)
flags+=(--volume "$home_dir:/home/hermes")

flags+=(--network="$net")
flags+=(--env HERMES_BASE_URL="http://ollama-$USER:11434/v1")
# If Hermes expects an API key variable, leave it empty or omit it.
flags+=(--env HERMES_API_KEY="")
# If Hermes also needs an explicit model name, you can set it:
flags+=(--env HERMES_MODEL="llama3.2:1b")

if ensure_allowed "$PWD"
then
  echo "$app: mounting $PWD in R/W mode"
  flags+=(--volume "$PWD:$PWD:rw")
  flags+=(--workdir "$PWD")
else
  echo "$app: directory $PWD is not whitelisted - NOT MOUNTING"
  flags+=(--workdir /tmp)
fi

flags+=("$img")

exec docker run "${flags[@]}" "$@"
