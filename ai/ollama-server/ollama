#!/bin/bash
set -euo pipefail
app=$(basename "$0")
img='ollama'
net='ollama-net'

cache_dir="$HOME/.cache/ollama"
mkdir -p "$cache_dir"

docker network inspect "$net" > /dev/null 2>&1 || docker network create "$net"

flags=()

stty -a > /dev/null 2>&1 && flags+=(--interactive)
flags+=(--tty)
flags+=(--rm)
flags+=(--init)
flags+=(--user="$(id -u):$(id -g)")
flags+=(--name="$img-$USER")

flags+=(--env         HOME=/opt/ollama)
flags+=(--volume "$cache_dir:/opt/ollama")

flags+=(--network="$net")
flags+=(--env OLLAMA_HOST="0.0.0.0:11434")

flags+=(--read-only)
flags+=("$img")

exec docker run "${flags[@]}" "$@"
